# Используем легковесный образ Node.js на базе Alpine Linux
FROM node:20-alpine

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем файлы конфигурации npm
COPY package*.json ./

# Устанавливаем ВСЕ зависимости (включая devDependencies для webpack)
RUN npm install

# Копируем остальные файлы проекта (папку src, index.html и т.д.)
COPY . .

# Шаг 3 из вашей инструкции: собираем бандл через webpack
RUN npx webpack

# Шаг 5 из вашей инструкции: запускаем сервер serve на порту 3000
# Флаг -l 3000 принудительно говорит serve слушать порт 3000 внутри контейнера
CMD ["npx", "serve", "-l", "3000", "."]
